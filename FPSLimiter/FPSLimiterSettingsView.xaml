<UserControl x:Class="FPSLimiter.FPSLimiterSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="640">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,16,24,16">
            <TextBlock Text="RTSS executable path"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding Settings.RtssPath, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="420" />
            <TextBlock Text="FPS Limiter fills this with the detected RTSS.exe path when it can. Clear it to let detection run again."
                       TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,4,0,16" />

            <CheckBox Content="Start RTSS automatically when applying a cap"
                      IsChecked="{Binding Settings.AutoStartRtss}"
                      Margin="0,0,0,8" />

            <CheckBox Content="Use RTSS Global profile while capped games are running"
                      IsChecked="{Binding Settings.UseGlobalProfileDuringLaunch}"
                      Margin="0,0,0,4" />
            <TextBlock Text="This is more reliable when per-executable RTSS profiles do not apply. The previous Global cap is restored when Playnite detects the game stopped."
                       TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,12" />

            <TextBlock Text="FPS Limiter edits RTSS profile files directly. Normal, non-admin Playnite needs write access to the RTSS Profiles folder."
                       TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,8" />

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,16">
                <Button Content="Test RTSS profile access"
                        Command="{Binding TestRtssProfilePermissionsCommand}"
                        MinWidth="160"
                        Margin="0,0,8,0" />
                <Button Content="Set up RTSS access..."
                        Command="{Binding FixRtssProfilePermissionsCommand}"
                        MinWidth="180" />
            </StackPanel>

            <TextBlock Text="FPS presets"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding Settings.PresetsText, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="420" />
            <TextBlock Text="Use comma-separated values. Decimals are supported (e.g. 59.9, 23.976) for displays without VRR that need an exact fractional cap. Spaces and trailing commas are fine; values are saved in a clean format."
                       TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,16" />

            <TextBlock Text="Desktop and Fullscreen limits are separate"
                       FontWeight="Bold"
                       Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,16">
                <Run Text="FPS Limiter now remembers a different cap, sync mode, and global fallback for Playnite's Desktop mode and Fullscreen mode. Whichever mode you're currently using is the one you're editing when you open a game's right-click menu or" />
                <Run Text=" Extensions &gt; FPS Limiter &gt; Global FPS limit" FontWeight="SemiBold" />
                <Run Text=". The menu heading shows which mode you're in, e.g. " />
                <Run Text="FPS Limiter (Fullscreen)" FontWeight="SemiBold" />
                <Run Text=". Set your TV/no-VRR cap while running Fullscreen mode and your monitor cap while running Desktop mode; they won't overwrite each other." />
            </TextBlock>

            <TextBlock Text="Global FPS limit and sync mode"
                       FontWeight="Bold"
                       Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,8">
                <Run Text="A fallback cap for games that don't have their own preset. It's only written to RTSS and only starts RTSS while a game using that fallback is running, and RTSS is closed again once no FPS Limiter caps are active. This is the same setting as Playnite's main menu under" />
                <Run Text=" Extensions &gt; FPS Limiter &gt; Global FPS limit" FontWeight="SemiBold" />
                <Run Text="; edit it here or there, whichever is handier. Desktop and Fullscreen have their own independent cap so you don't need to switch modes just to set the other one." />
            </TextBlock>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Desktop"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <CheckBox Grid.Column="1" Content="Enabled"
                          IsChecked="{Binding Settings.GlobalDesktop.Enabled}"
                          VerticalAlignment="Center" />
                <TextBox Grid.Column="3"
                         Text="{Binding Settings.GlobalDesktop.FrameLimitText, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding Settings.GlobalDesktop.Enabled}"
                         VerticalAlignment="Center" />
                <TextBlock Grid.Column="4" Text="FPS"
                           VerticalAlignment="Center"
                           Opacity="0.72"
                           Margin="4,0,0,0" />
                <TextBlock Grid.Column="6" Text="Sync mode"
                           VerticalAlignment="Center"
                           Opacity="0.72"
                           Margin="0,0,8,0" />
                <ComboBox Grid.Column="7"
                          ItemsSource="{Binding SyncModeOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding Settings.GlobalDesktop.SyncMode}"
                          IsEnabled="{Binding Settings.GlobalDesktop.Enabled}" />
                <TextBlock Grid.Column="9" Text="Reflex markers"
                           VerticalAlignment="Center"
                           Opacity="0.72"
                           Margin="0,0,8,0" />
                <ComboBox Grid.Column="10"
                          ItemsSource="{Binding ReflexMarkerOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding Settings.GlobalDesktop.ReflexMarkers}" />
            </Grid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Fullscreen"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <CheckBox Grid.Column="1" Content="Enabled"
                          IsChecked="{Binding Settings.GlobalFullscreen.Enabled}"
                          VerticalAlignment="Center" />
                <TextBox Grid.Column="3"
                         Text="{Binding Settings.GlobalFullscreen.FrameLimitText, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding Settings.GlobalFullscreen.Enabled}"
                         VerticalAlignment="Center" />
                <TextBlock Grid.Column="4" Text="FPS"
                           VerticalAlignment="Center"
                           Opacity="0.72"
                           Margin="4,0,0,0" />
                <TextBlock Grid.Column="6" Text="Sync mode"
                           VerticalAlignment="Center"
                           Opacity="0.72"
                           Margin="0,0,8,0" />
                <ComboBox Grid.Column="7"
                          ItemsSource="{Binding SyncModeOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding Settings.GlobalFullscreen.SyncMode}"
                          IsEnabled="{Binding Settings.GlobalFullscreen.Enabled}" />
                <TextBlock Grid.Column="9" Text="Reflex markers"
                           VerticalAlignment="Center"
                           Opacity="0.72"
                           Margin="0,0,8,0" />
                <ComboBox Grid.Column="10"
                          ItemsSource="{Binding ReflexMarkerOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding Settings.GlobalFullscreen.ReflexMarkers}" />
            </Grid>

            <TextBlock TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,16">
                <Run Text="Each game's right-click menu also has its own" />
                <Run Text=" Sync mode" FontWeight="SemiBold" />
                <Run Text=" and " />
                <Run Text="Reflex markers" FontWeight="SemiBold" />
                <Run Text=" submenus that override the global ones for that game. RTSS enables Reflex latency marker injection by default on every profile; &quot;Disabled&quot; here writes that override into the RTSS profile file. This is separate from the" />
                <Run Text=" NVIDIA Reflex" FontWeight="SemiBold" />
                <Run Text=" sync mode option above, which controls RTSS's Reflex framerate limiter instead." />
            </TextBlock>

            <TextBlock Text="VRR-safe FPS cap"
                       FontWeight="Bold"
                       Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,8">
                <Run Text="Suggests a cap comfortably under your display's current refresh rate using Blur Busters' formula (Refresh - Refresh" />
                <Run Text="&#178;" BaselineAlignment="Superscript" FontSize="10" />
                <Run Text=" / 3600), so frame delivery never outruns the VRR window right at the refresh-rate ceiling, which is what causes stutter." />
            </TextBlock>
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,4">
                <TextBlock Text="{Binding VrrSafeCapPreview}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <Button Content="Refresh"
                        Command="{Binding RefreshVrrSafeCapCommand}"
                        Padding="8,2"
                        Margin="0,0,8,0" />
                <Button Content="Add to presets"
                        Command="{Binding AddVrrSafeCapToPresetsCommand}"
                        Padding="8,2" />
            </StackPanel>
            <TextBlock Text="Use it as your Global FPS limit fallback instead of (or in addition to) a preset:"
                       TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,16">
                <Button Content="Set as Global (Desktop)"
                        Command="{Binding ApplyVrrSafeCapToGlobalDesktopCommand}"
                        Padding="8,2"
                        Margin="0,0,8,0" />
                <Button Content="Set as Global (Fullscreen)"
                        Command="{Binding ApplyVrrSafeCapToGlobalFullscreenCommand}"
                        Padding="8,2" />
            </StackPanel>

            <Separator Margin="0,16,0,16" />

            <TextBlock Text="Hotkeys"
                       FontWeight="Bold"
                       Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,8">
                <Run Text="Assign a global keyboard shortcut that instantly applies an FPS cap (or disables it) to whichever game currently has an active cap session. If no game is running, the shortcut applies to whatever's selected in your library instead. Click a shortcut box below and press the key combo you want; press " />
                <Run Text="Escape" FontWeight="SemiBold" />
                <Run Text=" while focused on it to clear it." />
            </TextBlock>

            <ItemsControl ItemsSource="{Binding Settings.Hotkeys}"
                          Margin="0,0,0,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding Enabled}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      ToolTip="Enable this hotkey" />

                            <TextBox Grid.Column="1"
                                     Text="{Binding DisplayText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     VerticalAlignment="Center"
                                     Padding="6,4"
                                     Cursor="Hand"
                                     ToolTip="Click here, then press a key combo"
                                     PreviewKeyDown="HotkeyCaptureBox_PreviewKeyDown" />

                            <CheckBox Grid.Column="3"
                                      Content="Disable cap"
                                      IsChecked="{Binding DisableCap}"
                                      VerticalAlignment="Center" />

                            <TextBox Grid.Column="5"
                                     Text="{Binding FrameLimitText, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center" />

                            <TextBlock Grid.Column="6"
                                       Text="FPS"
                                       VerticalAlignment="Center"
                                       Opacity="0.72"
                                       Margin="4,0,0,0" />

                            <Button Grid.Column="8"
                                    Content="Remove"
                                    Padding="8,2"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.RemoveHotkeyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="Add hotkey"
                    Command="{Binding AddHotkeyCommand}"
                    HorizontalAlignment="Left"
                    MinWidth="110" />

            <Separator Margin="0,16,0,16" />

            <TextBlock Text="VRR refresh rate switching"
                       FontWeight="Bold"
                       Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,8">
                <Run Text="Automatically changes the display refresh rate when an FPS cap at or below the threshold is applied, then restores the original rate when the game stops. Useful on laptops where VRR works better at a specific refresh rate (e.g. 48 Hz with a 40 FPS cap)." />
            </TextBlock>

            <CheckBox Content="Switch refresh rate for low FPS caps"
                      IsChecked="{Binding Settings.VrrRefreshRateEnabled}"
                      Margin="0,0,0,10" />

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Target refresh rate (Hz)"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Grid.Column="1"
                         Text="{Binding Settings.VrrTargetHz, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding Settings.VrrRefreshRateEnabled}" />

                <TextBlock Grid.Column="3" Text="FPS cap threshold"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Grid.Column="4"
                         Text="{Binding Settings.VrrFpsThreshold, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding Settings.VrrRefreshRateEnabled}" />
            </Grid>
            <TextBlock TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,4,0,0">
                <Run Text="When an FPS cap &lt;= the threshold is applied, the display switches to the target Hz. Set threshold to 40 and target to 48 to match your VRR sweet spot." />
            </TextBlock>

            <Separator Margin="0,16,0,16" />

            <TextBlock Text="Match refresh rate to FPS cap (non-VRR displays)"
                       FontWeight="Bold"
                       Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,8">
                <Run Text="For displays without VRR, this switches the refresh rate to a whole multiple of the active FPS cap (e.g. a 30 FPS cap switches the display to 60 Hz, a 36 FPS cap to 72 Hz), then restores the original rate when the game stops. This keeps every capped frame mapped to the same number of display refreshes, avoiding judder. Only the refresh rates your display actually supports are used; if none of them line up evenly with the cap, the refresh rate is left alone." />
            </TextBlock>

            <CheckBox Content="Switch refresh rate to match FPS cap"
                      IsChecked="{Binding Settings.MatchRefreshRateEnabled}"
                      Margin="0,0,0,10" />

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Highest multiplier to try (2x, 3x, ... up to)"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Grid.Column="1"
                         Text="{Binding Settings.MatchRefreshRateMaxMultiplier, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding Settings.MatchRefreshRateEnabled}" />
            </Grid>
            <TextBlock TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,4,0,0">
                <Run Text="2x is always tried first (the common case). Raise this if you want it to also try 3x or 4x the cap when your display doesn't support an exact 2x match." />
            </TextBlock>
            <TextBlock TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,4,0,0"
                       FontStyle="Italic">
                <Run Text="Note: only enable one of the two refresh-rate switching options above at a time — VRR switching is for displays with variable refresh rate, this one is for displays without it." />
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
