<UserControl x:Class="FPSLimiter.FPSLimiterSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="640">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,16,24,16">
            <TextBlock Text="RTSS executable path"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding Settings.RtssPath, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="420" />
            <TextBlock Text="FPS Limiter fills this with the detected RTSS.exe path when it can. Clear it to let detection run again."
                       TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,4,0,16" />

            <CheckBox Content="Start RTSS automatically when applying a cap"
                      IsChecked="{Binding Settings.AutoStartRtss}"
                      Margin="0,0,0,8" />

            <CheckBox Content="Use RTSS Global profile while capped games are running"
                      IsChecked="{Binding Settings.UseGlobalProfileDuringLaunch}"
                      Margin="0,0,0,4" />
            <TextBlock Text="This is more reliable when per-executable RTSS profiles do not apply. The previous Global cap is restored when Playnite detects the game stopped."
                       TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,12" />

            <TextBlock Text="FPS Limiter edits RTSS profile files directly. Normal, non-admin Playnite needs write access to the RTSS Profiles folder."
                       TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,8" />

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,16">
                <Button Content="Test RTSS profile access"
                        Command="{Binding TestRtssProfilePermissionsCommand}"
                        MinWidth="160"
                        Margin="0,0,8,0" />
                <Button Content="Set up RTSS access..."
                        Command="{Binding FixRtssProfilePermissionsCommand}"
                        MinWidth="180" />
            </StackPanel>

            <TextBlock Text="FPS presets"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding Settings.PresetsText, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="420" />
            <TextBlock Text="Use comma-separated values. Spaces and trailing commas are fine; values are saved in a clean format."
                       TextWrapping="Wrap"
                       Opacity="0.72" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
