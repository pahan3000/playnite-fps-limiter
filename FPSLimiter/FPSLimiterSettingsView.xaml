<UserControl x:Class="FPSLimiter.FPSLimiterSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="640">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,12,0">
            <TextBlock Text="RTSS executable path"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding Settings.RtssPath, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="420" />
            <TextBlock Text="Leave blank to auto-detect RTSS.exe."
                       TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,4,0,16" />

            <CheckBox Content="Start RTSS automatically when applying a cap"
                      IsChecked="{Binding Settings.AutoStartRtss}"
                      Margin="0,0,0,8" />

            <CheckBox Content="Use RTSS Global profile while capped games are running"
                      IsChecked="{Binding Settings.UseGlobalProfileDuringLaunch}"
                      Margin="0,0,0,4" />
            <TextBlock Text="This is more reliable when per-executable RTSS profiles do not apply. The previous Global cap is restored when Playnite detects the game stopped."
                       TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,8" />

            <CheckBox Content="Try direct RTSS profile file edits if the SDK save does not stick"
                      IsChecked="{Binding Settings.EnableProfileFileFallback}"
                      Margin="0,0,0,4" />
            <TextBlock Text="Requires Playnite to have write access to the RTSS Profiles folder, for example by running Playnite elevated or changing that folder's permissions."
                       TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,0,0,8" />

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,16">
                <Button Content="Test RTSS profile access"
                        Command="{Binding TestRtssProfilePermissionsCommand}"
                        MinWidth="160"
                        Margin="0,0,8,0" />
                <Button Content="Fix RTSS profile permissions..."
                        Command="{Binding FixRtssProfilePermissionsCommand}"
                        MinWidth="180" />
            </StackPanel>

            <TextBlock Text="FPS presets"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding Settings.PresetsText, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="420" />
            <TextBlock Text="Use comma-separated values. These presets appear in Desktop game menus and Fullscreen Extensions."
                       TextWrapping="Wrap"
                       Opacity="0.72"
                       Margin="0,4,0,16" />

            <TextBlock Text="Desktop mode also supports custom typed caps and manual target executable selection from each game's context menu."
                       TextWrapping="Wrap"
                       Opacity="0.72" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
